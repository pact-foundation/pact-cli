#!/usr/bin/env bash
# Smoke-test all built container images across target platforms.
#
# Environment:
#   CONTAINER_TAG - Version to test (e.g. 0.8.1). Required.
#   PLATFORMS     - Comma-separated platforms to test against.
#                   Default: linux/amd64,linux/arm64
set -euo pipefail

# Source the build script to inherit REGISTRIES, TARGET_CONTAINERFILE, and
# CONTAINER_TAG without executing the build.
# shellcheck source=./build
source "$(dirname "${BASH_SOURCE[0]}")/build"

readonly BOLD=$'\033[1m'
readonly DIM=$'\033[2m'
readonly GREEN=$'\033[32m'
readonly RED=$'\033[31m'
readonly RESET=$'\033[0m'
SEPARATOR="${BOLD}$(printf '─%.0s' {1..60})${RESET}"
readonly SEPARATOR

IFS=',' read -ra TEST_PLATFORMS <<<"${PLATFORMS}"

declare -a passed=()
declare -a failed=()

for registry in "${REGISTRIES[@]}"; do
	for key in "${!TARGET_CONTAINERFILE[@]}"; do
		suffix="${key#base}"
		image="${registry}/pact:${CONTAINER_TAG}${suffix}"
		for platform in "${TEST_PLATFORMS[@]}"; do
			printf "\n%s▶ Testing %s on %s%s\n" "${BOLD}" "${image}" "${platform}" "${RESET}"

			tmpfile=$(mktemp)
			if docker run --rm --platform "${platform}" "${image}" >"${tmpfile}" 2>&1; then
				passed+=("${image} [${platform}]")
			else
				failed+=("${image} [${platform}]")
			fi
			while IFS= read -r line; do
				printf "%s%s%s\n" "${DIM}" "${line}" "${RESET}"
			done <"${tmpfile}"
			rm -f "${tmpfile}"
		done
	done
done

printf "\n%s\n" "${SEPARATOR}"
printf "%s Results%s\n" "${BOLD}" "${RESET}"
printf "%s\n" "${SEPARATOR}"
for entry in "${passed[@]+"${passed[@]}"}"; do
	printf " %s✓%s  %s\n" "${GREEN}" "${RESET}" "${entry}"
done
for entry in "${failed[@]+"${failed[@]}"}"; do
	printf " %s✗%s  %s\n" "${RED}" "${RESET}" "${entry}"
done
printf "%s\n" "${SEPARATOR}"
printf " %s passed, %s failed\n" "${#passed[@]}" "${#failed[@]}"
printf "%s\n\n" "${SEPARATOR}"

[[ ${#failed[@]} -eq 0 ]]
